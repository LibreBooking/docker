#!/bin/bash
# Sanity-checks that env credentials actually work end-to-end.
# Run after start, before wasting time debugging the app logs.

set -uo pipefail

PASS=0
FAIL=0

GREEN='\033[0;32m'
RED='\033[0;31m'
RESET='\033[0m'

ok() {
	echo -e "${GREEN}[PASS]${RESET} $*"
	((PASS++))
}
fail() {
	echo -e "${RED}[FAIL]${RESET} $*"
	((FAIL++))
}

# Load app env vars
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENV_FILE="$SCRIPT_DIR/../quadlets/librebooking.env"
# shellcheck disable=SC1090
set -a
source <(grep -v '^#' "$ENV_FILE" | grep '=')
set +a

function describe($TITLE, )

echo "=== 1. Container status ==="
for svc in db app cron; do
	if systemctl --user is-active --quiet "${svc}.service" 2>/dev/null; then
		ok "${svc}.service is running"
	else
		fail "${svc}.service is NOT running"
	fi
done

echo ""
echo "=== 2. DB credentials (app user) ==="
if podman exec db mariadb \
	-u "$LB_DATABASE_USER" \
	-p"$LB_DATABASE_PASSWORD" \
	-e "USE \`$LB_DATABASE_NAME\`; SELECT 1;" \
	&>/dev/null; then
	ok "DB login: user='$LB_DATABASE_USER' db='$LB_DATABASE_NAME' password matches"
else
	fail "DB login FAILED for user='$LB_DATABASE_USER' db='$LB_DATABASE_NAME' — credentials mismatch or DB not ready"
fi

echo ""
echo "=== 3. Network reachability ==="
APP_URL="http://localhost:8080/Web"
HTTP_CODE=$(curl -s -o /dev/null -w "%{http_code}" --max-time 5 "$APP_URL" 2>/dev/null || echo "000")
if [[ "$HTTP_CODE" =~ ^(200|302)$ ]]; then
	ok "App responded HTTP $HTTP_CODE at $APP_URL"
else
	fail "App not reachable at $APP_URL (got HTTP $HTTP_CODE)"
fi

echo ""
echo "=== 4. App DB connection (no error in response) ==="
BODY=$(curl -s --max-time 5 "$APP_URL" 2>/dev/null || true)
if echo "$BODY" | grep -qi "DatabaseConnectionException\|Access denied\|mysqli_connect"; then
	fail "App response contains a DB connection error"
elif [[ -z "$BODY" ]]; then
	fail "App returned empty body"
else
	ok "App response contains no DB connection errors"
fi

echo ""
echo "=== Result: ${PASS} passed, ${FAIL} failed ==="
[[ $FAIL -eq 0 ]]
